# Server
PORT=3000
NODE_ENV=development

# Database (SQLite file path)
DATABASE_URL=./data/voting.db

# JWT (voter sessions)
JWT_SECRET=change-this-to-a-strong-random-secret
JWT_EXPIRES_IN=30m

# JWT (admin sessions)
ADMIN_JWT_SECRET=change-this-to-another-strong-secret
ADMIN_JWT_EXPIRES_IN=8h

# Blockchain
# Options: simulated | ganache | ethereum
# Use 'simulated' for development without Ganache.
# Use 'ganache' after running: node scripts/deploy-contract.js
BLOCKCHAIN_PROVIDER=simulated
BLOCKCHAIN_NODE_URL=http://127.0.0.1:8545
BLOCKCHAIN_CHAIN_ID=1337

# Smart contract address — auto-filled by deploy-contract.js
# Required only when BLOCKCHAIN_PROVIDER=ganache
CONTRACT_ADDRESS=

# Rate limiting (auth endpoints)
AUTH_RATE_LIMIT_WINDOW_MS=900000
AUTH_RATE_LIMIT_MAX=10

# CORS — restrict in production
CORS_ORIGIN=*
